---
// src/components/TarjetaServicio.astro
// SEO v2: alt estratégico por servicio · width/height explícitos para CLS
export interface Props {
    servicio: {
        id:               string;
        nombre:           string;
        categoria:        string;
        imagen:           string;
        descripcion_corta?: string;
    };
    eager?: boolean;
}

const { servicio, eager = false } = Astro.props;

/*
 Alt estratégico — fórmula: "[Servicio] en [Ciudad] — [Marca]"
 Cubre los 6 servicios reales. Fallback genérico si el id cambia.
*/
const altMap: Record<string, string> = {
    "pisos-laminados":  "Instalación de piso laminado AC5 en Bogotá — Instalaciones Tirado S.A.S",
    "spc":              "Instalación de piso SPC para zonas húmedas en Bogotá — Instalaciones Tirado S.A.S",
    "decks":            "Construcción de deck de madera para terraza en Colombia — Instalaciones Tirado S.A.S",
    "pergolas":         "Pérgola de madera para patio exterior en Bogotá — Instalaciones Tirado S.A.S",
    "cabanas":          "Cabaña de madera maciza para glamping en Colombia — Instalaciones Tirado S.A.S",
    "escaleras":        "Escalera de madera maciza instalada en Bogotá — Instalaciones Tirado S.A.S",
    "pulida-sin-polvo": "Pulida de pisos de madera sin polvo sistema dust-free en Bogotá — Instalaciones Tirado S.A.S",
};

const altText = altMap[servicio.id]
    ?? `${servicio.nombre} en Colombia — Instalaciones Tirado S.A.S`;
---

<a
    href={`/servicios/${servicio.id}`}
    class="group block no-underline w-24 md:w-28 mx-auto"
    aria-label={`Ver detalle: ${servicio.nombre}`}
>
    <div class="relative bg-white p-1 shadow-md transition-all duration-500 group-hover:shadow-xl group-hover:-translate-y-1 border border-slate-100">

        <div class="relative overflow-hidden bg-slate-50 border border-slate-200">
            <img
                src={servicio.imagen}
                alt={altText}
                class="img-square transition-all duration-700 grayscale-[30%] group-hover:grayscale-0 group-hover:scale-110"
                loading={eager ? "eager" : "lazy"}
                width="112"
                height="112"
                decoding="async"
            />
        </div>

        <div class="pt-2 pb-1 text-center">
            <h3 class="text-[8px] font-bold text-nogal uppercase tracking-tighter truncate leading-none">
                {servicio.nombre}
            </h3>
            <p class="text-[6px] text-oro-premium font-medium uppercase tracking-[0.2em] mt-1">
                {servicio.categoria}
            </p>
        </div>

    </div>
</a>
