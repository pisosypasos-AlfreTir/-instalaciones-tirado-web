---
// src/components/Header.astro
---
<header class="header">
    <nav class="nav-container">
        <a href="/" class="logo-container">
            <img src="/imagenes/Logo.png" alt="Instalaciones Tirado SAS" class="logo-img" />
            <span class="logo-text">Instalaciones Tirado</span>
        </a>
        <div class="nav-links">
            <a href="/" class="nav-btn">Inicio</a>
            <a href="/servicios" class="nav-btn">Servicios</a>
            <a href="/contacto" class="nav-btn contact-btn">Contacto</a>
        </div>
    </nav>
</header>

<style>
  .header {
    background-color: #2D241E; /* nogal */
    color: white;
    box-shadow: 0 4px 24px rgba(45, 36, 30, 0.18);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-img {
    height: 48px;   /* Proporcional — antes era 170px */
    width: auto;
    display: block;
  }

  .logo-text {
    font-family: 'Playfair Display', serif; /* Sistema tipográfico del proyecto */
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: white;
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .nav-btn {
    padding: 0.5rem 1.1rem;
    border-radius: 2px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.75);
    background-color: transparent;
    transition: color 0.2s, background-color 0.2s;
    display: inline-block;
    text-decoration: none;
  }

  .nav-btn:hover {
    color: #C9A84C; /* oro-premium */
    background-color: rgba(201, 168, 76, 0.08);
  }

  .contact-btn {
    color: #2D241E;           /* nogal */
    background-color: #C9A84C; /* oro-premium */
    font-weight: 700;
    padding: 0.5rem 1.4rem;
    border-radius: 2px;
  }

  .contact-btn:hover {
    background-color: #fff;
    color: #2D241E;
  }
</style>