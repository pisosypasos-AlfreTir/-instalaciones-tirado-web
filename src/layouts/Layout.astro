---
// src/layouts/Layout.astro
import '../styles/globals.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BotonWhatsapp from '../components/BotonWhatsapp.astro';

export interface Props {
    title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Instalaciones Tirado SAS — Carpintería de autor y estructuras en madera maciza. Escaleras, pisos y techos de alta calidad en Bogotá, Colombia." />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/Tronco-.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <meta name="generator" content={Astro.generator} />
        <title>{title} | Instalaciones Tirado SAS</title>
    </head>
    <body class="relative">
        <Header />

        <main class="min-h-screen">
            <slot />
        </main>

        <Footer />

        <BotonWhatsapp />
    </body>
</html>
