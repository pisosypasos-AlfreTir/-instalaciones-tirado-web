---
// src/pages/contacto.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto — Instalaciones Tirado SAS">

    <div class="contacto-wrapper">

        <!-- Encabezado -->
        <div class="contacto-hero">
            <span class="contacto-eyebrow">Estamos para ayudarte</span>
            <h1 class="contacto-titulo">Hablemos de tu proyecto</h1>
            <div class="contacto-divider"></div>
            <p class="contacto-subtitulo">
                ¿Tienes un proyecto en mente? Cuéntanos los detalles y te damos una cotización personalizada sin compromiso.
            </p>
        </div>

        <div class="contacto-grid">

            <!-- Formulario -->
            <div class="contacto-form-card">
                <h2 class="card-titulo">Envíanos un mensaje</h2>

                <form id="contactForm" class="form-fields">
                    <div class="field-group">
                        <label for="nombre" class="field-label">Nombre completo</label>
                        <input type="text" id="nombre" name="nombre"
                            class="field-input" placeholder="Tu nombre" required />
                    </div>

                    <div class="field-group">
                        <label for="email" class="field-label">Correo electrónico</label>
                        <input type="email" id="email" name="email"
                            class="field-input" placeholder="tucorreo@gmail.com" required />
                    </div>

                    <div class="field-group">
                        <label for="telefono" class="field-label">Teléfono <span class="field-opcional">(opcional)</span></label>
                        <input type="tel" id="telefono" name="telefono"
                            class="field-input" placeholder="+57 321 456 7890" />
                    </div>

                    <div class="field-group">
                        <label for="mensaje" class="field-label">Mensaje</label>
                        <textarea id="mensaje" name="mensaje" rows="5"
                            class="field-input field-textarea"
                            placeholder="Describe tu proyecto o consulta..." required></textarea>
                    </div>

                    <button type="submit" class="btn-enviar">
                        Enviar mensaje
                    </button>

                    <div id="form-success" class="form-success" style="display:none;">
                        ✓ Mensaje enviado. Te contactaremos pronto.
                    </div>
                </form>
            </div>

            <!-- Info + Accesos directos -->
            <div class="contacto-info-col">

                <div class="info-card">
                    <h2 class="card-titulo">Nuestra información</h2>
                    <ul class="info-list">
                        <li>
                            <span class="info-icon">📍</span>
                            <span>Carrera 20 # 161 - 36, Toberín • Bogotá D.C., Colombia</span>
                        </li>
                        <li>
                            <span class="info-icon">📞</span>
                            <a href="tel:+573132566705" class="info-link">+57 313 256 6705</a>
                        </li>
                        <li>
                            <span class="info-icon">✉️</span>
                            <a href="pisosypasos@gmail.com" class="info-link">pisosypasos@gmail.com</a>
                        </li>
                        <li>
                            <span class="info-icon">🕐</span>
                            <span>Lunes – Viernes: 7:00 – 18:00</span>
                        </li>
                    </ul>
                </div>

                <div class="contacto-directo-card">
                    <h2 class="card-titulo">Contacto directo</h2>
                    <div class="btns-directos">
                        <a href="https://wa.me/573132566705?text=Hola,%20me%20gustaría%20solicitar%20información%20sobre%20sus%20servicios."
                           target="_blank" rel="noopener noreferrer" class="btn-directo btn-wa">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
                            </svg>
                            WhatsApp
                        </a>
                        <a href="pisosypasos@gmail.com?subject=Consulta%20desde%20la%20web"
                           class="btn-directo btn-email">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                                <path d="M22 4H2c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h20c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 2v.5L12 13 2 6.5V6h20zM2 18V7.5l10 6.5 10-6.5V18H2z"/>
                            </svg>
                            Correo electrónico
                        </a>
                    </div>
                </div>

            </div>
        </div>

        <!-- Mapa — Bogotá D.C. -->
      <div class="mapa-wrapper">
          <h2 class="card-titulo mapa-titulo">Nuestra ubicación</h2>
          <div class="mapa-container">
              <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.280145456428!2d-74.0487042!3d4.7439369!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f850b61699939%3A0x6b1686a978f85f3!2sCra.%2020%20%23161-36%2C%20Bogot%C3%A1!5e0!3m2!1ses-419!2sco!4v1700000000000!5m2!1ses-419!2sco"
                  width="100%"
                  height="360"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Ubicación Instalaciones Tirado SAS — Bogotá"
              ></iframe>
          </div>
      </div>
    </div>

</Layout>

<style>
  .contacto-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem 6rem;
  }

  /* ── Encabezado ── */
  .contacto-hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .contacto-eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #C9A84C; /* oro-premium */
    margin-bottom: 1rem;
  }

  .contacto-titulo {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: #2D241E; /* nogal */
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
  }

  .contacto-divider {
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, #C9A84C, transparent);
    margin: 0 auto 1.5rem;
  }

  .contacto-subtitulo {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    color: #64748b;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Grid principal ── */
  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .contacto-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 2.5rem;
    }
  }

  /* ── Cards ── */
  .contacto-form-card,
  .info-card,
  .contacto-directo-card {
    background: #fff;
    border: 1px solid #e8e2da;
    padding: 2rem 2rem 2.25rem;
  }

  .contacto-info-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .card-titulo {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #2D241E; /* nogal */
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  /* ── Formulario ── */
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .field-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #2D241E;
    letter-spacing: 0.01em;
  }

  .field-opcional {
    font-weight: 400;
    color: #94a3b8;
  }

  .field-input {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: #1e293b;
    background: #fdfcfb;
    border: 1px solid #d6cfc6;
    padding: 0.75rem 1rem;
    border-radius: 2px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .field-input:focus {
    border-color: #C9A84C;
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.12);
  }

  .field-textarea {
    resize: vertical;
    min-height: 130px;
  }

  .btn-enviar {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: white;
    background-color: #2D241E; /* nogal */
    border: none;
    padding: 1rem 2rem;
    cursor: pointer;
    width: 100%;
    transition: background-color 0.2s, transform 0.15s;
  }

  .btn-enviar:hover {
    background-color: #C9A84C; /* oro-premium */
    color: #2D241E;
    transform: translateY(-1px);
  }

  .form-success {
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #16a34a;
    font-weight: 600;
    padding: 0.75rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
  }

  /* ── Info card ── */
  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: #475569;
  }

  .info-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .info-icon {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .info-link {
    color: #2D241E;
    text-decoration: none;
    transition: color 0.2s;
  }

  .info-link:hover {
    color: #C9A84C;
  }

  /* ── Botones directos ── */
  .btns-directos {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .btn-directo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    padding: 0.875rem 1.5rem;
    border-radius: 2px;
    transition: filter 0.2s, transform 0.15s;
  }

  .btn-directo:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .btn-wa {
    background-color: #25D366;
    color: white;
  }

  .btn-email {
    background-color: #2D241E;
    color: white;
  }

  /* ── Mapa ── */
  .mapa-wrapper {
    background: #fff;
    border: 1px solid #e8e2da;
    padding: 2rem;
  }

  .mapa-titulo {
    text-align: center;
  }

  .mapa-container {
    overflow: hidden;
    border-radius: 2px;
  }
</style>

<script>
    const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
    const formSuccess = document.getElementById('form-success');

    if (contactForm && formSuccess) {
        contactForm.addEventListener('submit', function(event) {
            event.preventDefault();
            formSuccess.style.display = 'block';
            contactForm.reset();
        });
    }
</script>