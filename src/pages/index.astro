---
// src/pages/index.astro
// Hero.astro usa background-image CSS animado (madera-slide @keyframes).
// NO modificar Hero.astro. Las secciones nuevas se construyen aquí con
// continuidad visual: paleta nogal/#2D241E + oro/#C9A84C + blanco/crema.
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import servicios from '../data/servicios.json';
import TarjetaServicio from '../components/TarjetaServicio.astro';

// TITLE: keyword de alta intención + ciudad (sin "Maderas" genérico)
// Layout añade "| Instalaciones Tirado S.A.S" al final automáticamente
const title = "Pérgolas, Decks, Cabañas y Pisos de Madera en Bogotá";

// DESCRIPTION propia del home (Layout tiene un fallback, pero esta es más específica)
const description = "Instalaciones Tirado S.A.S · Instalación profesional de pisos, pérgolas, decks y cabañas en Bogotá. +30 años de oficio, garantía por escrito. ☎ 313 256 6705";

const serviciosDestacados = servicios.filter(s => s.destacado);
---

<Layout title={title} description={description}>
<div class="page-wrapper">

    <!-- ══════════════════════════════════════════
         HERO — NO TOCAR. Ver Hero.astro.
         background-image CSS + madera-slide.
    ══════════════════════════════════════════ -->
    <Hero />


    <!-- ══════════════════════════════════════════
         BANDA DE CIFRAS
         Flota sobre el Hero con margin-top negativo.
         bg-nogal casi opaco con borde inferior oro.
    ══════════════════════════════════════════ -->
    <div class="cifras-wrapper">
        <section class="cifras-band parallax" data-speed="0.08">

            <div class="cifra-item group">
                <span class="cifra-numero group-hover:scale-110">30+</span>
                <span class="cifra-label">Años de oficio</span>
            </div>

            <div class="cifra-sep" aria-hidden="true"></div>

            <div class="cifra-item group">
                <span class="cifra-numero group-hover:scale-110">500+</span>
                <span class="cifra-label">Obras terminadas</span>
            </div>

            <div class="cifra-sep" aria-hidden="true"></div>

            <div class="cifra-item group">
                <span class="cifra-numero group-hover:scale-110">100%</span>
                <span class="cifra-label">Garantía por escrito</span>
            </div>

            <div class="cifra-sep" aria-hidden="true"></div>

            <!-- Cobertura nacional: ícono de mapa + texto, sin número grande -->
            <div class="cifra-item cifra-item--cobertura group">
                <span class="cifra-cobertura-ico" aria-hidden="true">
                    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Silueta esquemática de Colombia -->
                        <path
                            d="M13 4 L19 4 L21 7 L20 10 L23 12 L22 16 L19 18 L20 22 L17 26 L14 28 L11 25 L10 21 L12 18 L10 15 L11 11 L9 8 Z"
                            stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="none"
                        />
                        <!-- Pin de ubicación centrado -->
                        <circle cx="16" cy="15" r="2" fill="currentColor" opacity=".7"/>
                        <line x1="16" y1="17" x2="16" y2="20" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                </span>
                <span class="cifra-numero cifra-numero--cobertura group-hover:scale-110">Nacional</span>
                <span class="cifra-label">Cobertura · Colombia</span>
            </div>

        </section>
    </div>


    <!-- ══════════════════════════════════════════
         SECCIÓN 01 — SOBRE NOSOTROS
         Fondo: blanco crema #fdfcfb.
         Imagen estática de taller/obra a la derecha.
         Texto: 30 años, fidelidad técnica, diferenciador.
    ══════════════════════════════════════════ -->
    <section id="sobre-nosotros" class="sobre-section">

        <!-- Columna texto -->
        <div class="sobre-texto anim-reveal">

            <span class="sec-eyebrow">Sobre nosotros</span>

            <h2 class="sec-h2">
                Treinta años instalando madera<br/>
                <span class="sec-h2-light">con criterio técnico en Colombia.</span>
            </h2>

            <div class="sec-divider" aria-hidden="true"></div>

            <p class="sec-p">
                Instalaciones Tirado S.A.S lleva tres décadas en obra. No en ventas, no en promesas:
                en obra real. Residencias particulares, hoteles, oficinas de alta gama y proyectos
                de rehabilitación histórica, con presencia y cobertura en todo el territorio nacional.
            </p>

            <p class="sec-p" style="--anim-delay: 0.15s">
                Nuestro diferenciador no es el precio ni el marketing. Es la fidelidad técnica:
                respetamos los tiempos de aclimatación de cada especie, ejecutamos las juntas de
                dilatación con la holgura que exige la normativa y usamos solo adhesivos y barnices
                certificados de alta gama. Esos detalles son los que deciden si un parqué dura
                cinco años o cincuenta.
            </p>

            <ul class="sobre-lista" style="--anim-delay: 0.25s">
                <li>
                    <span class="lista-ico" aria-hidden="true">—</span>
                    Instalación según normativas técnicas vigentes
                </li>
                <li>
                    <span class="lista-ico" aria-hidden="true">—</span>
                    Asesoramiento en la compra del material antes de la obra
                </li>
                <li>
                    <span class="lista-ico" aria-hidden="true">—</span>
                    Nivelación de soleras previa cuando la base lo requiere
                </li>
                <li>
                    <span class="lista-ico" aria-hidden="true">—</span>
                    Mantenimiento post-instalación: lijado y barnizado
                </li>
            </ul>

        </div>

        <!-- Columna imagen: reemplaza src con tu foto de obra/taller real -->
        <div class="sobre-imagen anim-reveal" style="--anim-delay: 0.1s">
            <div class="sobre-img-frame">
                <!--
                    REEMPLAZA con tu imagen real de obra o taller.
                    Dimensiones recomendadas: 800×1000px, orientación vertical.
                    Ejemplo: src="/imagenes/taller-instalaciones-tirado.jpg"
                -->
                <img
                    src="/imagenes/escalera-cerezo.jpg"
                    alt="Instalación de escalera de madera maciza en Bogotá — Instalaciones Tirado S.A.S"
                    class="sobre-img"
                    loading="lazy"
                    width="800"
                    height="1000"
                />
                <!-- Filete decorativo oro en la esquina -->
                <div class="sobre-img-deco" aria-hidden="true"></div>
            </div>

            <!-- Tarjeta flotante de dato clave -->
            <div class="sobre-dato-flotante">
                <span class="dato-flotante-num">30</span>
                <span class="dato-flotante-txt">años de oficio continuo<br/>en instalación de madera</span>
            </div>
        </div>

    </section>


    <!-- ══════════════════════════════════════════
         SECCIÓN 02 — SERVICIOS TÉCNICOS
         Fondo: nogal oscuro para contraste fuerte
         tras la sección blanca de Sobre Nosotros.
         Grid de tarjetas de servicio con icono SVG,
         título técnico y descripción de ejecución.
    ══════════════════════════════════════════ -->
    <section id="servicios" class="servicios-section">

        <div class="servicios-header anim-reveal">
            <span class="sec-eyebrow sec-eyebrow--claro">Especialidades técnicas</span>
            <h2 class="sec-h2 sec-h2--claro">
                Instalación de pisos, pérgolas y decks<br/>
                <span class="sec-h2-light sec-h2-light--oro">en Bogotá y toda Colombia.</span>
            </h2>
            <p class="servicios-intro">
                Cada servicio sigue un protocolo de ejecución estricto. No improvisamos fases
                ni materiales. El resultado es una instalación estable, sin ruidos y sin desniveles.
            </p>
        </div>

        <!-- Grid de servicios: 3 columnas en desktop -->
        <div class="servicios-grid">

            <!-- Servicio 1 — Pisos Laminados y SPC -->
            <article class="serv-card anim-reveal" style="--anim-delay: 0.05s">
                <div class="serv-icon" aria-hidden="true">
                    <!-- Icono: capas de piso laminado (capa base + clic + capa de uso) -->
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="10" width="40" height="6"  rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <rect x="4" y="20" width="40" height="6"  rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <rect x="4" y="30" width="40" height="6"  rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <!-- Clic macho-hembra derecha -->
                        <path d="M44 23 L44 20 L48 20 L48 26 L44 26" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        <!-- Indicador de capas -->
                        <line x1="2" y1="10" x2="2" y2="36" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="serv-titulo">Instalación de Pisos Laminados y SPC en Bogotá</h3>
                <p class="serv-desc">
                    Suministro e instalación de pisos de alta resistencia con acabados modernos
                    y duraderos. Trabajamos con laminado AC4/AC5 y SPC rígido de núcleo de piedra,
                    ideales para alto tránsito, zonas húmedas y proyectos residenciales o comerciales.
                </p>
                <span class="serv-normativa">Laminado AC4–AC5 · SPC núcleo rígido</span>
            </article>

            <!-- Servicio 2 — Decks y Exteriores -->
            <article class="serv-card anim-reveal" style="--anim-delay: 0.15s">
                <div class="serv-icon" aria-hidden="true">
                    <!-- Icono: decking exterior con tornillo/fijación oculta -->
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="10" width="40" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <rect x="4" y="21" width="40" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <rect x="4" y="32" width="40" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <circle cx="12" cy="13.5" r="2" fill="currentColor"/>
                        <circle cx="36" cy="24.5" r="2" fill="currentColor"/>
                        <circle cx="24" cy="35.5" r="2" fill="currentColor"/>
                    </svg>
                </div>
                <h3 class="serv-titulo">Construcción de Decks de Madera para Exteriores en Colombia</h3>
                <p class="serv-desc">
                    Instalación de plataformas de madera tratada o sintética, ideales para
                    zonas húmedas y áreas sociales. Fijación oculta que elimina tornillos a la
                    vista, garantiza drenaje correcto y protege la tabla frente a la intemperie.
                </p>
                <span class="serv-normativa">Fijación oculta · Madera tratada clase 4</span>
            </article>

            <!-- Servicio 3 — Pulida de Pisos Sin Polvo -->
            <article class="serv-card anim-reveal" style="--anim-delay: 0.25s">
                <div class="serv-icon" aria-hidden="true">
                    <!-- Icono: máquina lijadora orbital con tubo de aspiración -->
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Cuerpo de la máquina -->
                        <rect x="10" y="20" width="28" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/>
                        <!-- Plato lijador (base) -->
                        <rect x="8"  y="34" width="32" height="4"  rx="2" stroke="currentColor" stroke-width="1.3"/>
                        <!-- Tubo de aspiración -->
                        <path d="M30 20 C30 14, 36 12, 40 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                        <circle cx="40" cy="7" r="2.5" stroke="currentColor" stroke-width="1.2"/>
                        <!-- Partículas de polvo aspiradas (líneas curvas subiendo al tubo) -->
                        <path d="M28 18 C29 15, 31 14, 33 15" stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none" opacity=".6"/>
                        <path d="M24 17 C25 13, 28 12, 30 13" stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none" opacity=".4"/>
                        <!-- Superficie del suelo -->
                        <line x1="4" y1="38" x2="44" y2="38" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-dasharray="3 2"/>
                    </svg>
                </div>
                <h3 class="serv-titulo">Pulida y Restauración de Pisos de Madera Sin Polvo en Bogotá</h3>
                <p class="serv-desc">
                    Restauración profesional de madera natural mediante tecnología de succión
                    integrada: el polvo se captura en origen sin contaminar el ambiente. Incluye
                    lijado, sellado de juntas y acabado con barniz o aceite de alta resistencia.
                </p>
                <span class="serv-normativa">Succión en origen · Polvo cero · Barnices sin COV</span>
            </article>

            <!-- Servicio 4 — Pérgolas y Estructuras -->
            <article class="serv-card anim-reveal" style="--anim-delay: 0.1s">
                <div class="serv-icon" aria-hidden="true">
                    <!-- Icono: pérgola vista de frente con vigas y montantes -->
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <line x1="8"  y1="8"  x2="8"  y2="42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <line x1="40" y1="8"  x2="40" y2="42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <line x1="6"  y1="8"  x2="42" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <line x1="16" y1="8"  x2="16" y2="24" stroke="currentColor" stroke-width="1.2"/>
                        <line x1="24" y1="8"  x2="24" y2="24" stroke="currentColor" stroke-width="1.2"/>
                        <line x1="32" y1="8"  x2="32" y2="24" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                </div>
                <h3 class="serv-titulo">Diseño y Construcción de Pérgolas de Madera en Bogotá</h3>
                <p class="serv-desc">
                    Creación de techos y estructuras en madera para transformar terrazas y patios
                    en espacios funcionales. Cálculo de cargas, anclajes homologados y tratamiento
                    de impregnación según la clase de riesgo de cada pieza estructural.
                </p>
                <span class="serv-normativa">Anclajes homologados · Clase de riesgo 3–4</span>
            </article>

            <!-- Servicio 5 — Construcción de Cabañas -->
            <article class="serv-card anim-reveal" style="--anim-delay: 0.2s">
                <div class="serv-icon" aria-hidden="true">
                    <!-- Icono: cabaña en madera con cubierta a dos aguas y troncos -->
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Techo a dos aguas -->
                        <polyline points="4,22 24,6 44,22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <!-- Cuerpo de la cabaña -->
                        <rect x="8" y="22" width="32" height="18" rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <!-- Troncos horizontales (3 líneas) -->
                        <line x1="8"  y1="28" x2="40" y2="28" stroke="currentColor" stroke-width="1"/>
                        <line x1="8"  y1="33" x2="40" y2="33" stroke="currentColor" stroke-width="1"/>
                        <!-- Puerta centrada -->
                        <rect x="20" y="30" width="8" height="10" rx="1" stroke="currentColor" stroke-width="1.2"/>
                        <!-- Chimenea -->
                        <rect x="30" y="9" width="4" height="8" rx="0.5" stroke="currentColor" stroke-width="1.2"/>
                        <!-- Humo (líneas onduladas) -->
                        <path d="M32 9 C31 7, 33 5, 32 3" stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none" opacity=".5"/>
                    </svg>
                </div>
                <h3 class="serv-titulo">Diseño y Construcción de Cabañas de Madera en Colombia</h3>
                <p class="serv-desc">
                    Diseño y ejecución de proyectos campestres en madera, uniendo estética
                    rústica con solidez estructural. Desde la cimentación hasta el acabado interior:
                    estructura, cubierta, carpintería y revestimientos en un solo contrato.
                </p>
                <span class="serv-normativa">Estructura certificada · Madera seca de cámara</span>
            </article>

            <!-- Servicio 6 — Escaleras de Lujo -->
            <article class="serv-card anim-reveal" style="--anim-delay: 0.3s">
                <div class="serv-icon" aria-hidden="true">
                    <!-- Icono: escalera en perspectiva con peldaños y pasamanos -->
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Peldaños en escalera (vista lateral) -->
                        <polyline points="6,42 6,34 14,34 14,26 22,26 22,18 30,18 30,10 42,10"
                                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <!-- Zanca (línea diagonal de base) -->
                        <line x1="6" y1="42" x2="42" y2="42" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                        <!-- Pasamanos (paralelo a los peldaños, desplazado arriba) -->
                        <polyline points="6,36 6,30 14,30 14,22 22,22 22,14 30,14 30,6 42,6"
                                  stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity=".5"/>
                        <!-- Balaustres (3 verticales) -->
                        <line x1="10" y1="34" x2="10" y2="30" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                        <line x1="20" y1="26" x2="20" y2="22" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                        <line x1="28" y1="18" x2="28" y2="14" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="serv-titulo">Fabricación e Instalación de Escaleras de Madera de Lujo en Colombia</h3>
                <p class="serv-desc">
                    Diseño, fabricación y revestimiento de escaleras que se convierten en la
                    pieza central del hogar. Trabajamos en madera maciza, ingeniería o combinada
                    con vidrio y acero, con tolerancia de mecanizado ±0,5 mm en cada peldaño.
                </p>
                <span class="serv-normativa">CTE DB-SUA · Tolerancia ±0,5 mm · A medida</span>
            </article>

        </div>

        <!-- CTA dentro de la sección de servicios -->
        <div class="servicios-cta anim-reveal" style="--anim-delay: 0.35s">
            <a href="/servicios" class="btn-servicios-sec">
                Ver galería de proyectos finalizados →
            </a>
        </div>

    </section>


    <!-- ══════════════════════════════════════════
         SECCIÓN 03 — GARANTÍA Y CALIDAD
         Fondo: crema/blanco con franja nogal a la
         izquierda como separador visual.
         Tres columnas con el proceso de garantía.
    ══════════════════════════════════════════ -->
    <section id="garantia" class="garantia-section">

        <!-- Franja lateral decorativa (solo desktop) -->
        <div class="garantia-franja" aria-hidden="true">
            <span class="garantia-franja-txt">GARANTÍA · NORMATIVA · CALIDAD</span>
        </div>

        <div class="garantia-contenido">

            <div class="garantia-header anim-reveal">
                <span class="sec-eyebrow">Garantía y calidad</span>
                <h2 class="sec-h2">
                    Una instalación correcta<br/>
                    <span class="sec-h2-light">no da problemas en cinco años.</span>
                </h2>
                <div class="sec-divider" aria-hidden="true"></div>
                <p class="sec-p">
                    No hablamos de promesas. Hablamos de estabilidad, acabados y normativa.
                    Cada trabajo que entregamos incluye documentación técnica y garantía por escrito
                    sobre la mano de obra.
                </p>
            </div>

            <!-- Tres pilares de garantía -->
            <div class="garantia-pilares">

                <div class="pilar anim-reveal" style="--anim-delay: 0.05s">
                    <div class="pilar-num">01</div>
                    <div class="pilar-linea" aria-hidden="true"></div>
                    <h4 class="pilar-titulo">Ejecución bajo normativa</h4>
                    <p class="pilar-desc">
                        Todas las instalaciones siguen las normativas técnicas vigentes
                        (UNE, ISO, CTE). No son estándares opcionales: son el mínimo exigible
                        para que la madera se comporte como debe durante décadas.
                    </p>
                </div>

                <div class="pilar anim-reveal" style="--anim-delay: 0.18s">
                    <div class="pilar-num">02</div>
                    <div class="pilar-linea" aria-hidden="true"></div>
                    <h4 class="pilar-titulo">Materiales certificados</h4>
                    <p class="pilar-desc">
                        Solo usamos adhesivos, barnices y sistemas de fijación con ficha
                        técnica y certificación europea. Nunca materiales sin trazabilidad.
                        El proveedor y el lote quedan registrados en el dossier de obra.
                    </p>
                </div>

                <div class="pilar anim-reveal" style="--anim-delay: 0.32s">
                    <div class="pilar-num">03</div>
                    <div class="pilar-linea" aria-hidden="true"></div>
                    <h4 class="pilar-titulo">Garantía por escrito</h4>
                    <p class="pilar-desc">
                        Al terminar la obra entregamos un certificado de garantía sobre
                        la mano de obra. Si aparece algún problema técnico imputable a
                        la instalación, lo resolvemos. Sin letra pequeña, sin discusiones.
                    </p>
                </div>

                <!-- Pilar 04: Cobertura nacional -->
                <div class="pilar pilar--cobertura anim-reveal" style="--anim-delay: 0.44s">
                    <div class="pilar-num">04</div>
                    <div class="pilar-linea" aria-hidden="true"></div>
                    <!-- Ícono mapa Colombia inline -->
                    <span class="pilar-mapa-ico" aria-hidden="true">
                        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M16 5 L24 5 L26.5 9 L25 13 L28.5 15.5 L27.5 20.5 L24 23 L25 27.5 L21 33 L17 35.5 L13.5 32 L12.5 27 L15 23 L12.5 19.5 L14 14.5 L11 10.5 Z"
                                stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="rgba(201,168,76,0.08)"
                            />
                            <!-- Pin ubicación -->
                            <path d="M20 19 C20 19, 23.5 15.5, 23.5 13.5 C23.5 11.57 21.93 10 20 10 C18.07 10 16.5 11.57 16.5 13.5 C16.5 15.5 20 19 20 19Z"
                                  stroke="currentColor" stroke-width="1.3" fill="none"/>
                            <circle cx="20" cy="13.5" r="1.5" fill="currentColor"/>
                        </svg>
                    </span>
                    <h4 class="pilar-titulo">Cobertura nacional</h4>
                    <p class="pilar-desc">
                        Operamos en todo el territorio colombiano. Bogotá es nuestra base,
                        pero desplazamos equipo a cualquier ciudad para proyectos que lo
                        requieran. Un solo interlocutor técnico para toda la obra.
                    </p>
                </div>

            </div>

            <!-- Bloque de proceso: 4 pasos lineales -->
            <div class="proceso-wrapper anim-reveal" style="--anim-delay: 0.4s">
                <h3 class="proceso-titulo">Cómo trabajamos en cada obra</h3>
                <ol class="proceso-pasos">
                    <li class="paso">
                        <span class="paso-num">1</span>
                        <div>
                            <strong class="paso-tit">Estudio previo</strong>
                            <span class="paso-txt">Medición, diagnóstico de la base y asesoramiento sobre el material más adecuado para la estancia.</span>
                        </div>
                    </li>
                    <li class="paso">
                        <span class="paso-num">2</span>
                        <div>
                            <strong class="paso-tit">Preparación de solera</strong>
